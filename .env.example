# Public app URL. For LAN access, use http://<your-computer-lan-ip>:3000.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Anorvis OS / agent chat
# Start anorvis-os locally and use its gateway token for web chat.
ANORVIS_OS_URL=http://127.0.0.1:8787
# ANORVIS_OS_API_TOKEN=
# ANORVIS_OS_API_TOKEN_PATH=~/.anorvis/os/api-token
# ANORVIS_REPO_ROOT=/absolute/path/to/anorvis
# BUN_BIN=bun
# ANORVIS_WEB_AGENT_TIMEOUT_MS=300000
