# Public app URL. For LAN access, use http://<your-computer-lan-ip>:3000.
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Vercel sets VERCEL_ENV in hosted deployments.
# Production and preview deployments serve only the public landing page at /; all other paths 404.
# Unset and development values run the local/private app.


# Anorvis OS gateway
# Start anorvis-os locally for local data and integration APIs.
ANORVIS_OS_URL=http://127.0.0.1:8787
# ANORVIS_OS_API_TOKEN=
# ANORVIS_OS_API_TOKEN_PATH=~/.anorvis/os/api-token
